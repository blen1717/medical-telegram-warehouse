LEFT JOIN "warehouse"."main"."dim_channels" d_ch ON s.channel_name = d_ch.channel_name
LEFT JOIN "warehouse"."main"."dim_dates" d_dt ON DATE(s.message_date) = d_dt.full_date
    );
  
  
