    create  table
      "warehouse"."main"."fct_messages__dbt_tmp"
  
    as (
      SELECT
    s.message_key,
    s.message_id,
    d_ch.channel_key,
    d_dt.date_key,
    s.message_text,
    s.message_length,
    s.views AS view_count,
    s.forwards AS forward_count,
    s.has_image_flag AS has_image
